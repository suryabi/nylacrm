{
  "project_name": "Nyla Air Water - Sales Target Planning & Allocation System",
  "design_context": "dashboard",
  "theme": "light",
  "design_philosophy": {
    "primary_goal": "Create an intuitive, spreadsheet-like enterprise planning interface with clear visual hierarchy and real-time validation feedback",
    "emotional_tone": "Professional, trustworthy, efficient, calm",
    "visual_mood": "Clean minimal aesthetic with organic warmth",
    "key_principles": [
      "Spreadsheet-like clarity for data entry and allocation",
      "Clear parent-child hierarchical relationships",
      "Real-time validation with visual feedback",
      "Progressive disclosure (expand/collapse)",
      "Generous spacing for breathing room",
      "High information density without clutter",
      "Desktop-first with mobile-friendly review mode"
    ]
  },
  "color_system": {
    "archetype": "ORGANIC & EARTHY (Trust, Growth, Calm)",
    "rationale": "Enterprise planning tool for leadership requires trust, clarity, and calm decision-making environment. Organic palette with sage green and warm beige creates grounded, professional atmosphere without corporate coldness",
    "palette": {
      "primary": {
        "value": "hsl(155, 35%, 42%)",
        "hex": "#4A9B7F",
        "usage": "CTAs, active states, success indicators, primary actions",
        "contrast_note": "Sage green - meets WCAG AA for white text"
      },
      "accent": {
        "value": "hsl(42, 85%, 65%)",
        "hex": "#F4C542",
        "usage": "Warnings, pending states, highlights, attention markers",
        "contrast_note": "Warm golden yellow - use with dark text only"
      },
      "destructive": {
        "value": "hsl(0, 72%, 60%)",
        "hex": "#E84855",
        "usage": "Over-allocation warnings, errors, delete actions",
        "contrast_note": "Coral red - softer than pure red, maintains urgency"
      },
      "background": {
        "value": "hsl(40, 30%, 97%)",
        "hex": "#F9F7F4",
        "usage": "Main background - warm off-white",
        "tint_note": "Tinted with warm beige, never pure white"
      },
      "background_secondary": {
        "value": "hsl(38, 35%, 94%)",
        "hex": "#F3EFE8",
        "usage": "Cards, panels, secondary surfaces",
        "tint_note": "Slightly darker warm beige for layering"
      },
      "foreground": {
        "value": "hsl(25, 15%, 25%)",
        "hex": "#4A4238",
        "usage": "Primary text - warm dark brown",
        "contrast_note": "Tinted with warm undertone, not pure black"
      },
      "foreground_muted": {
        "value": "hsl(25, 10%, 45%)",
        "hex": "#7A6F64",
        "usage": "Secondary text, labels, metadata",
        "contrast_note": "Warm grey for hierarchy"
      },
      "border": {
        "value": "hsl(35, 15%, 88%)",
        "hex": "#E5DFD6",
        "usage": "Subtle borders, dividers, table lines",
        "tint_note": "Warm tinted grey, not neutral"
      },
      "validation_colors": {
        "success": "hsl(155, 35%, 42%)",
        "warning": "hsl(42, 85%, 65%)",
        "error": "hsl(0, 72%, 60%)",
        "info": "hsl(210, 50%, 55%)"
      }
    },
    "contrast_rules": {
      "text_on_background": "4.5:1 minimum (WCAG AA)",
      "text_on_primary": "White text on sage green meets AA",
      "text_on_accent": "Dark text required on yellow",
      "interactive_elements": "3:1 minimum against adjacent colors",
      "hover_states": "Always explicitly set text color on hover - never rely on inheritance"
    }
  },
  "typography": {
    "font_families": {
      "heading": {
        "family": "Manrope",
        "weights": [300, 400, 500, 600, 700, 800],
        "usage": "All headings (h1-h6), section titles, page titles",
        "rationale": "Geometric sans with warmth - professional yet approachable",
        "import": "Already imported in index.css"
      },
      "subheading": {
        "family": "Work Sans",
        "weights": [400, 500, 600],
        "usage": "Subheadings, labels, overlines, table headers",
        "rationale": "Clean sans for hierarchy and clarity",
        "import": "Already imported in index.css"
      },
      "body": {
        "family": "IBM Plex Sans",
        "weights": [300, 400, 500],
        "usage": "Body text, paragraphs, descriptions, table cells",
        "rationale": "Highly legible for data-heavy interfaces",
        "import": "Already imported in index.css"
      },
      "mono": {
        "family": "IBM Plex Mono",
        "weights": [400, 500],
        "usage": "Numbers, currency values, IDs, codes",
        "rationale": "Monospace for numerical alignment and precision",
        "import": "Already imported in index.css"
      }
    },
    "scale": {
      "page_title": "text-3xl md:text-4xl font-heading font-bold tracking-tight",
      "section_title": "text-2xl md:text-3xl font-heading font-semibold tracking-tight",
      "card_title": "text-xl font-heading font-semibold",
      "subsection_title": "text-lg font-subheading font-medium",
      "table_header": "text-sm font-subheading font-medium uppercase tracking-wide",
      "body_large": "text-base font-body",
      "body_default": "text-sm font-body",
      "body_small": "text-xs font-body",
      "label": "text-xs font-subheading font-medium uppercase tracking-wider",
      "number_display": "font-mono tabular-nums"
    },
    "line_height": {
      "tight": "leading-tight (headings, titles)",
      "normal": "leading-normal (body text)",
      "relaxed": "leading-relaxed (long-form content)"
    },
    "letter_spacing": {
      "tighter": "tracking-tighter (large headings >32px)",
      "tight": "tracking-tight (headings)",
      "normal": "tracking-normal (body)",
      "wide": "tracking-wide (labels)",
      "wider": "tracking-wider (uppercase labels)"
    }
  },
  "spacing_system": {
    "philosophy": "Generous spacing (2-3x typical) for breathing room and clarity",
    "scale": {
      "xs": "p-1 (4px)",
      "sm": "p-2 (8px)",
      "md": "p-4 (16px)",
      "lg": "p-6 (24px)",
      "xl": "p-8 (32px)",
      "2xl": "p-12 (48px)",
      "3xl": "p-16 (64px)",
      "4xl": "p-20 (80px)",
      "5xl": "p-24 (96px)"
    },
    "application": {
      "page_container": "px-6 md:px-8 lg:px-12 py-6 md:py-8",
      "card_padding": "p-6 md:p-8",
      "section_spacing": "space-y-8 md:space-y-12",
      "table_cell": "px-4 py-3",
      "button_padding": "px-4 py-2 (default), px-6 py-3 (large)",
      "input_padding": "px-4 py-2",
      "gap_between_elements": "gap-4 md:gap-6"
    },
    "critical_rules": [
      "Containers with borders MUST have internal padding (p-6 or p-8)",
      "Never let text touch container edges",
      "Use optical alignment over geometric alignment",
      "Mobile: reduce spacing by 25-33% but maintain hierarchy"
    ]
  },
  "layout_patterns": {
    "grid_system": {
      "type": "High Density Grid (Dashboard Mode B)",
      "base_grid": "grid-cols-1 md:grid-cols-3 lg:grid-cols-4",
      "gap_strategy": "gap-4 md:gap-6 (tight for data correlation)",
      "span_logic": {
        "summary_cards": "col-span-1 (single metric cards)",
        "main_allocation_area": "col-span-2 md:col-span-3 (primary workspace)",
        "hierarchy_tree": "col-span-1 md:col-span-1 (sidebar tree view)",
        "validation_panel": "col-span-full (full-width alerts)"
      },
      "alignment": "align-items: start (override default stretch)",
      "mobile_first": "Always start with grid-cols-1"
    },
    "page_layouts": {
      "target_plan_list": {
        "structure": "Header + Filter Bar + Grid of Plan Cards + Pagination",
        "grid": "grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      },
      "allocation_workspace": {
        "structure": "Header + Breadcrumb + Main Grid (Tree Sidebar + Allocation Area) + Validation Footer",
        "layout": "Two-column: 1/4 tree navigation, 3/4 allocation workspace",
        "responsive": "Stack vertically on mobile with collapsible tree"
      },
      "plan_creation_form": {
        "structure": "Centered form card (max-w-2xl) with clear sections",
        "layout": "Single column with grouped fields"
      }
    },
    "component_layouts": {
      "allocation_table": {
        "type": "Spreadsheet-like table with inline editing",
        "columns": "Territory/City Name | Target Amount | Allocated Amount | Remaining | Progress Bar | Actions",
        "features": "Sticky header, zebra striping, hover states, inline input fields"
      },
      "hierarchy_tree": {
        "type": "Expandable/collapsible tree with indentation",
        "levels": "Country → Territory → State → City → Resource",
        "visual": "Indent by 16px per level, use icons for expand/collapse, show allocation status badges"
      },
      "summary_cards": {
        "type": "Metric cards with icon, label, value, and mini progress",
        "layout": "Grid of 4 cards (Total Target, Allocated, Remaining, Progress %)"
      }
    }
  },
  "component_strategy": {
    "shadcn_components": {
      "use_cases": [
        "Table (for allocation grids)",
        "Button (all interactive actions)",
        "Input (inline editing, form fields)",
        "Select (dropdowns for filters)",
        "Dialog (modals for confirmations)",
        "Badge (status indicators)",
        "Progress (allocation progress bars)",
        "Accordion (collapsible sections)",
        "Tabs (switching between views)",
        "Calendar (date range picker)",
        "Tooltip (contextual help)",
        "Alert (validation messages)",
        "Separator (visual dividers)",
        "Skeleton (loading states)"
      ],
      "customization_required": [
        "Override default Shadcn styling to match warm organic palette",
        "Adjust border-radius to match --radius: 0.75rem",
        "Ensure hover states explicitly set text colors",
        "Add data-testid attributes to all interactive elements"
      ]
    },
    "custom_components_needed": [
      "AllocationRow (table row with inline editing)",
      "HierarchyTreeNode (recursive tree component)",
      "ValidationAlert (custom alert with allocation status)",
      "ProgressIndicator (custom progress with labels)",
      "AllocationInput (input with validation and formatting)",
      "StatusBadge (custom badge with allocation states)"
    ],
    "component_conventions": {
      "exports": "Named exports for components (export const ComponentName)",
      "pages": "Default exports for pages (export default function PageName)",
      "location": "Components in src/components/, Pages in src/pages/",
      "styling": "Tailwind classes only, no inline styles",
      "state": "Simple useState, avoid complex nested state"
    }
  },
  "surface_strategies": {
    "header": {
      "style": "Solid background with subtle bottom border",
      "background": "bg-background-secondary",
      "border": "border-b border-border",
      "height": "h-16",
      "padding": "px-6 md:px-8",
      "position": "sticky top-0 z-50",
      "rationale": "Solid for clarity, not glass (data-heavy context)"
    },
    "cards": {
      "style": "Flat with subtle border, no shadow by default",
      "background": "bg-background-secondary",
      "border": "border border-border",
      "radius": "rounded-lg",
      "padding": "p-6 md:p-8",
      "hover": "hover:border-primary/40 hover:shadow-sm transition-all duration-200"
    },
    "tables": {
      "style": "Grid borders (technical look)",
      "background": "bg-background",
      "borders": "border-b border-border/40 on rows",
      "header": "bg-background-secondary border-b-2 border-border",
      "hover": "hover:bg-primary/5 transition-colors",
      "zebra": "Optional: even:bg-background-secondary/50"
    },
    "modals": {
      "style": "Solid card with overlay",
      "overlay": "bg-black/40 backdrop-blur-sm",
      "card": "bg-background border border-border rounded-lg shadow-xl",
      "padding": "p-6 md:p-8"
    },
    "sidebar": {
      "style": "Solid with right border",
      "background": "bg-background-secondary",
      "border": "border-r border-border",
      "width": "w-64 md:w-80",
      "padding": "p-4 md:p-6"
    }
  },
  "motion_and_interactions": {
    "required_animations": [
      "Hover states on all interactive elements",
      "Click/press states (scale-95 or brightness shift)",
      "Focus states with ring (focus-visible:ring-2 focus-visible:ring-ring)",
      "Expand/collapse animations for tree nodes",
      "Progress bar transitions",
      "Modal enter/exit animations",
      "Loading skeleton animations"
    ],
    "transition_properties": {
      "default": "transition-colors duration-200",
      "transform": "transition-transform duration-200 ease-out",
      "opacity": "transition-opacity duration-200",
      "all_interactive": "transition-all duration-200",
      "never_use": "transition: all (breaks transforms)"
    },
    "hover_states": {
      "buttons": "hover:bg-primary/90 hover:text-primary-foreground",
      "table_rows": "hover:bg-primary/5",
      "cards": "hover:border-primary/40 hover:shadow-sm hover:-translate-y-0.5",
      "links": "hover:text-primary hover:underline",
      "critical_rule": "ALWAYS explicitly set text color on hover"
    },
    "focus_states": {
      "all_interactive": "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2",
      "inputs": "focus:border-primary focus:ring-2 focus:ring-primary/20"
    },
    "loading_states": {
      "skeleton": "animate-pulse bg-muted",
      "spinner": "animate-spin",
      "progress": "transition-all duration-300 ease-out"
    },
    "accessibility": {
      "reduced_motion": "Respect prefers-reduced-motion media query",
      "decorative_elements": "Add aria-hidden='true' to decorative icons",
      "focus_management": "Ensure keyboard navigation works smoothly"
    }
  },
  "icons_and_assets": {
    "icon_library": {
      "primary": "lucide-react (already installed)",
      "rationale": "Clean, consistent, matches Tailwind sizing",
      "usage": "All UI icons (ChevronDown, Plus, Check, X, AlertCircle, etc.)"
    },
    "icon_usage": {
      "tree_expand_collapse": "ChevronRight (collapsed), ChevronDown (expanded)",
      "actions": "Plus (add), Trash2 (delete), Edit (edit), Lock (finalize)",
      "status": "CheckCircle (complete), AlertCircle (warning), XCircle (error)",
      "navigation": "ArrowLeft (back), Home, Menu",
      "data": "TrendingUp, TrendingDown, DollarSign, Users"
    },
    "icon_sizing": {
      "small": "w-4 h-4 (16px)",
      "default": "w-5 h-5 (20px)",
      "large": "w-6 h-6 (24px)",
      "hero": "w-8 h-8 (32px)"
    },
    "images": {
      "not_required": "This is a data-heavy dashboard - no decorative images needed",
      "logo": "Nyla Air Water logo in header (to be provided by client)",
      "empty_states": "Use illustrations or icons for empty states"
    }
  },
  "validation_and_feedback": {
    "validation_states": {
      "fully_allocated": {
        "color": "text-primary",
        "badge": "bg-primary/10 text-primary border-primary/20",
        "icon": "CheckCircle",
        "message": "Fully allocated"
      },
      "under_allocated": {
        "color": "text-accent",
        "badge": "bg-accent/10 text-accent-foreground border-accent/20",
        "icon": "AlertCircle",
        "message": "Under-allocated by ₹X"
      },
      "over_allocated": {
        "color": "text-destructive",
        "badge": "bg-destructive/10 text-destructive border-destructive/20",
        "icon": "XCircle",
        "message": "Over-allocated by ₹X"
      },
      "not_started": {
        "color": "text-muted-foreground",
        "badge": "bg-muted text-muted-foreground",
        "icon": "Circle",
        "message": "Not allocated"
      }
    },
    "progress_indicators": {
      "type": "Progress bar with percentage label",
      "colors": {
        "0-50%": "bg-destructive (red - under-allocated)",
        "51-99%": "bg-accent (yellow - partial)",
        "100%": "bg-primary (green - complete)"
      },
      "display": "Show percentage and absolute values (₹X / ₹Y)"
    },
    "real_time_validation": {
      "trigger": "On input change (debounced 300ms)",
      "display": "Inline validation messages below inputs",
      "summary": "Validation summary panel at bottom of allocation workspace",
      "blocking": "Prevent finalization if validation fails"
    },
    "toast_notifications": {
      "library": "sonner (already installed)",
      "usage": "Success/error feedback for actions (save, delete, finalize)",
      "position": "top-right",
      "duration": "3000ms (success), 5000ms (error)"
    }
  },
  "data_display_patterns": {
    "currency_formatting": {
      "format": "₹X,XX,XXX (Indian numbering system)",
      "component": "Use Intl.NumberFormat with 'en-IN' locale",
      "display": "font-mono tabular-nums for alignment",
      "example": "₹12,34,567"
    },
    "percentage_display": {
      "format": "XX.X%",
      "rounding": "1 decimal place",
      "display": "font-mono tabular-nums"
    },
    "date_display": {
      "format": "DD MMM YYYY (e.g., 15 Jan 2024)",
