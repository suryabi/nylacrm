  "technical_constraints": {
    "framework": "React (JavaScript, not TypeScript)",
    "styling": "Tailwind CSS",
    "components": "Shadcn UI primitives",
    "state_management": "Simple useState, avoid complex nested state",
    "array_operations": "Avoid complex array operations (babel compatibility)",
    "file_extensions": ".js and .jsx (not .tsx)",
    "backend": "FastAPI (APIs already built and working)",
    "data_format": "JSON responses from backend"
  },
  "universal_guidelines": {
    "avoid_ai_slop": [
      "No generic centered layouts",
      "No simplistic gradients",
      "No uniform styling everywhere",
      "Create depth through layered design with z-index hierarchy"
    ],
    "transitions": [
      "NEVER use 'transition: all' - breaks transforms",
      "Always specify transition properties explicitly",
      "Example: transition-colors, transition-transform, transition-opacity"
    ],
    "text_alignment": [
      "NEVER center-align the entire app container",
      "Left-align body text, forms, tables for natural reading flow",
      "Center-align only specific elements (headings, CTAs) when appropriate"
    ],
    "button_styles": [
      "Modern pill-shaped or sharp buttons with rounded-lg",
      "Interaction animations (hover, active states)",
      "Colors relevant to app style (sage green primary)"
    ],
    "no_emoji_icons": [
      "NEVER use emoji characters for icons",
