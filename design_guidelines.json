  "page_specifications": {
    "target_plan_list": {
      "purpose": "View all target plans, select one to work on",
      "layout": "Header + Filter Bar + Grid of Plan Cards + Pagination",
      "components": [
        "Header with 'Create New Plan' button",
        "Filter bar (Year, Status, Search)",
        "Plan cards showing: Name, Period, Total Target, Status, Progress",
        "Pagination controls"
      ],
      "interactions": [
        "Click card to open allocation workspace",
        "Filter and search plans",
        "Create new plan button opens creation form"
      ]
    },
