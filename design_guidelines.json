  "accessibility": {
    "contrast": {
      "standard": "WCAG AA (4.5:1 for normal text, 3:1 for large text)",
      "tool": "Use APCA contrast calculator for accuracy",
      "critical_rule": "Always test text on colored backgrounds"
    },
    "keyboard_navigation": {
      "focus_visible": "Clear focus indicators on all interactive elements",
      "tab_order": "Logical tab order following visual hierarchy",
      "shortcuts": "Consider keyboard shortcuts for common actions"
    },
    "screen_readers": {
      "aria_labels": "Add aria-label to icon-only buttons",
      "aria_hidden": "Add aria-hidden='true' to decorative elements",
      "semantic_html": "Use proper heading hierarchy (h1, h2, h3)"
    },
    "testing_attributes": {
      "data_testid": "MUST add to all interactive and key informational elements",
