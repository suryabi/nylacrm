    "hierarchy_display": {
      "indentation": "16px per level (pl-4 per level)",
      "connectors": "Subtle vertical lines (border-l border-border)",
      "badges": "Show allocation status at each level",
      "expand_icon": "ChevronRight/ChevronDown before label"
    },
    "table_patterns": {
      "sticky_header": "sticky top-0 z-10 bg-background-secondary",
      "zebra_striping": "even:bg-background-secondary/50",
      "hover_highlight": "hover:bg-primary/5",
      "inline_editing": "Click cell to edit, show input with focus",
      "action_column": "Right-aligned with icon buttons"
    }
  },
