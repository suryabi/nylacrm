    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    },
    "strategy": "Desktop-first for planning, mobile-friendly for review",
    "mobile_adaptations": {
      "allocation_workspace": "Stack tree and allocation area vertically, collapsible tree",
      "tables": "Horizontal scroll with sticky first column",
